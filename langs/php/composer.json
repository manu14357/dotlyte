{
    "name": "dotlyte/dotlyte",
    "version": "0.1.1",
    "description": "The universal .env and configuration library for PHP — load, validate, encrypt, interpolate, and watch config from any source.",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.12"
    },
    "autoload": {
        "psr-4": {
            "Dotlyte\\": "src/"
        },
        "files": [
            "src/DotlyteException.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Dotlyte\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse"
    }
}
