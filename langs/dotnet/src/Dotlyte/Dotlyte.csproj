<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Dotlyte</RootNamespace>
    <PackageId>Dotlyte</PackageId>
    <Version>2.0.0</Version>
    <Authors>DOTLYTE Contributors</Authors>
    <Description>The universal .env and configuration library for .NET — with encryption, schema validation, interpolation, and masking.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://dotlyte.dev</PackageProjectUrl>
    <RepositoryUrl>https://github.com/dotlyte-io/dotlyte</RepositoryUrl>
    <PackageTags>config;env;dotenv;yaml;json;toml;configuration</PackageTags>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

</Project>
